# Paste4Ever API config
# Copy to .env and fill in.

# Local antd daemon (see scripts/start-antd.ps1). Leave default for localhost.
ANTD_URL=http://localhost:8082

# SQLite file for the local wall index. Rebuilds from scratch per environment —
# the source of truth for paste bytes is Autonomi itself.
PASTES_DB=pastes.db

# Port we listen on.
PORT=8080

# tracing filter. Default in code is paste4ever_api=debug,tower_http=info.
# RUST_LOG=paste4ever_api=info

# Cloudflare Turnstile secret key (NOT the site key — that one is public and
# lives in the web app). When set, every /paste must carry a valid token.
# Leave unset for local dev so curl / localhost work without a challenge.
# Get one at https://dash.cloudflare.com → Turnstile → Add site.
# TURNSTILE_SECRET_KEY=0x4AAAAAAA...
