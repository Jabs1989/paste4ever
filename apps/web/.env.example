# Paste4Ever web config
# Copy to .env.local and fill in.

# Rust API base URL (server-side fetches only).
RUST_API_URL=http://localhost:8080

# Public base URL of the Rust API. When set, the browser calls the API
# directly (bypassing the Next.js /api/* proxy) — required in production
# because Cloudflare Workers cannot reach a same-zone tunnel via fetch()
# (returns error 1003). Leave unset for local dev; the proxy routes at
# /api/* will forward to RUST_API_URL on the server side.
# NEXT_PUBLIC_API_URL=https://api.paste4ever.com

# Cloudflare Turnstile SITE key (public — ships in the client bundle).
# Pair with TURNSTILE_SECRET_KEY on the Rust API side.
# Leave unset for local dev: the widget + server check will both turn off,
# so you can paste without completing a challenge.
# Get one at https://dash.cloudflare.com → Turnstile → Add site.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
